{
  "name": "webclaw-static",
  "version": "1.0.0",
  "description": "WebClaw AI agent - static website bundle. Zero dependencies, runs in browser.",
  "main": "dist-bundle/index.html",
  "bin": {
    "webclaw-static": "./bin/webclaw-static.js"
  },
  "files": [
    "dist-bundle/",
    "dist-singlefile/",
    "bin/",
    "README.md",
    "LICENSE"
  ],
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "build:analyze": "vite build --mode analyze",
    "build:singlefile": "node scripts/build-singlefile.js",
    "build:singlefile:ultimate": "INLINE_WASM=true node scripts/build-singlefile.js",
    "build:all": "npm run build && npm run build:singlefile && npm run build:singlefile:ultimate",
    "preview": "vite preview",
    "serve": "vite preview --port 8080",
    "prepublishOnly": "npm run build:all",
    "format": "prettier --write .",
    "lint": "eslint . --ext .js,.ts"
  },
  "devDependencies": {
    "@types/node": "^20.11.0",
    "autoprefixer": "^10.4.17",
    "postcss": "^8.4.35",
    "prettier": "^3.2.5",
    "rollup-plugin-visualizer": "^5.12.0",
    "tailwindcss": "^3.4.1",
    "terser": "^5.46.0",
    "typescript": "^5.3.3",
    "vite": "^5.0.12",
    "vite-plugin-compression": "^0.5.1",
    "vite-plugin-static-copy": "^1.0.0",
    "vite-plugin-wasm": "^3.3.0"
  },
  "keywords": [
    "webclaw",
    "ai",
    "agent",
    "wasm",
    "browser",
    "openclaw",
    "llm",
    "chat",
    "static"
  ],
  "author": "gleicon <gleicon@gmail.com>",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/gleicon/webclaw.git",
    "directory": "webclaw-static"
  },
  "bugs": {
    "url": "https://github.com/gleicon/webclaw/issues"
  },
  "homepage": "https://github.com/gleicon/webclaw#readme",
  "engines": {
    "node": ">=14.0.0"
  },
  "dependencies": {
    "just-bash": "^2.11.15"
  }
}
