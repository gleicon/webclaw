# Test credentials for automated UAT
# Copy this to .env.test and fill in your actual keys
# This file is gitignored - never commit real credentials!

# Required for provider failover tests (at least 2 recommended)
ANTHROPIC_API_KEY=***REMOVED***
OPENAI_API_KEY=***REMOVED***
OPENROUTER_API_KEY=your_openrouter_key_here

# Optional: For embedding/hybrid search tests
# If not provided, BM25-only mode will be tested
OPENAI_API_KEY_EMBED=***REMOVED***

# Optional: Test model selection (defaults shown)
ANTHROPIC_MODEL=claude-3-5-sonnet-20241022
OPENAI_MODEL=gpt-4o-mini
